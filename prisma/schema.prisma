// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum CfaScope {
  IFIR
  SPORT
  BOTH
}

enum EventType {
  SALON
  JPO
  FORUM
  WEBINAIRE
  PARTENAIRE
  INTERNE
  AUTRE
}

enum EventStatus {
  VEILLE
  A_ARBITRER
  DEVIS_DEMANDE
  DEVIS_RECU
  VALIDE
  INSCRIT
  A_PREPARER
  TERMINE
  BILAN_A_FAIRE
}

enum EventPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum EventReportStatus {
  PAS_FAIT
  EN_COURS
  FAIT
}

model Event {
  id                String            @id @default(cuid())
  title             String
  eventType         EventType
  cfaScope          CfaScope
  status            EventStatus
  startDate         DateTime
  durationDays      Float?            @default(1)
  endDate           DateTime?
  location          String?
  owner             String?
  priority          EventPriority     @default(MEDIUM)
  mainGoal          String?
  notes             String?
  budgetEstimated   Float?
  budgetNotes       String?
  participantsIfir  Int?
  participantsSport Int?
  reportStatus      EventReportStatus @default(PAS_FAIT)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([startDate])
  @@index([status])
}
